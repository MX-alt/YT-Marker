{
  "manifest_version": 3,
  "name": "YT-Marker",
  "version": "1.0",
  "description": "Mark YouTube videos as watched.",
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": [
    "storage", 
    "contextMenus", 
    "identity"
  ],
  "host_permissions": [
    "https://github.com/*"
  ]
}